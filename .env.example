# Personal News Digest — Local Development Only
# For GitHub Actions, use Repository Secrets instead.
# Copy to .env and fill in your values.

# LLM Provider: claude or gemini
LLM_PROVIDER=claude
# LLM_MODEL=claude-haiku-4-5-20251001

# API Keys (provide the one you're using)
ANTHROPIC_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here

# Gmail SMTP
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_TO=recipient@example.com

# Notification
NOTIFICATION_METHODS=email

# Optional: point to weekly config
# CONFIG_PATH=config-weekly.yaml

# Optional: custom email subject
# EMAIL_SUBJECT=Daily Digest
